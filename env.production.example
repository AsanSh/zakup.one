# Production environment variables for zakup.one
# Скопируйте этот файл как .env на сервере и настройте значения

# Database - use SQLite for simplicity, or configure PostgreSQL if available
DATABASE_URL=sqlite:///./zakup.db

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
DEBUG=False
API_V1_PREFIX=/api/v1

# CORS - add your domain
CORS_ORIGINS=["https://www.zakup.one","https://zakup.one","http://www.zakup.one","http://zakup.one"]

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Email settings (configure if needed)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@zakup.one
MAIL_FROM_NAME=ZAKUP.ONE
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True



